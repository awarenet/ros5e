{
  "name": "ros5e",
  "version": "1.0.0",
  "description": "This is a ruins of symbaroum module for foundryvtt.",
  "type": "module",
  "private": true,
  "scripts": {
    "brew": "npm run build:clean && npm run build:index",
    "brew:index": "node brew/_node/generate-index.js",
    "brew:clean": "npm run build:clean:base",
    "brew:clean:base": "node brew/_node/clean-and-test.js",
    "brew:clean:html": "node brew/_node/clean-html.js",
    "test:json": "test-json-brew",
    "test:file-contents": "node brew/_test/test-file-contents.js",
    "test:file-locations": "test-file-locations",
    "test:file-names": "test-file-names",
    "test:file-props": "test-file-props",
    "test:img-directories": "node brew/_test/test-img-dir.js",
    "test:html": "node brew/_test/test-html.js",
    "test:all": "npm run build:clean && npm run test:json && npm run test:file-locations && npm run test:file-names && npm run test:file-props && npm run test:img-directories && npm run test:file-contents && npm run test:html"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/awarenet/RoS5e.git"
  },
  "devDependencies": {
    "@foundryvtt/foundryvtt-cli": "^1.0.2",
    "5etools-utils": "^0.14.31",
    "commander": "^9.4.1",
    "he": "^1.2.0",
    "sanitize-html": "^2.12.1"
  },
  "author": "hoba",
  "license": "ISC",
  "bugs": {
    "url": "https://github.com/awarenet/RoS5e/issues"
  }
}

<div
  class="flexcol corruption-dialog-container"
  style="padding: 0.5rem; gap: 0.5rem;"
  data-threshold-base="{{thresholdBase}}"
>
  <div class="form-group">
    <label>{{localize "ROS5E.Corruption.Temporary"}}</label>
    <div class="form-fields">
      <input
        type="number"
        name="temp"
        value="{{corruption.temp}}"
        min="0"
        step="1"
        data-modifier="{{modifiers.temp}}"
      />
      <div class="field-metadata">
        {{#if modifiers.temp}}
          <span
            class="modifier"
            title="{{localize 'ROS5E.Corruption.ModifiersDesc'}}"
          >
            (+{{modifiers.temp}}
            {{localize "ROS5E.Corruption.Modifiers"}})
          </span>
        {{/if}}
        <span class="total">{{localize "ROS5E.Corruption.Total"}}:
          <span
            class="total-value"
            data-field="temp"
          >{{totals.temp}}</span></span>
      </div>
    </div>
  </div>

  <div class="form-group">
    <label>{{localize "ROS5E.Corruption.Permanent"}}</label>
    <div class="form-fields">
      <input
        type="number"
        name="permanent"
        value="{{corruption.permanent}}"
        min="0"
        step="1"
        data-modifier="{{modifiers.permanent}}"
      />
      <div class="field-metadata">
        {{#if modifiers.permanent}}
          <span
            class="modifier"
            title="{{localize 'ROS5E.Corruption.ModifiersDesc'}}"
          >
            (+{{modifiers.permanent}}
            {{localize "ROS5E.Corruption.Modifiers"}})
          </span>
        {{/if}}
        <span class="total">{{localize "ROS5E.Corruption.Total"}}:
          <span
            class="total-value"
            data-field="permanent"
          >{{totals.permanent}}</span></span>
      </div>
    </div>
  </div>

  <div class="form-group">
    <label>{{localize "ROS5E.Corruption.Bonus"}}</label>
    <div class="form-fields">
      <input
        type="number"
        name="bonus"
        value="{{corruption.bonus}}"
        min="0"
        step="1"
        data-modifier="{{modifiers.bonus}}"
      />
      <div class="field-metadata">
        {{#if modifiers.bonus}}
          <span
            class="modifier"
            title="{{localize 'ROS5E.Corruption.ModifiersDesc'}}"
          >
            (+{{modifiers.bonus}}
            {{localize "ROS5E.Corruption.Modifiers"}})
          </span>
        {{/if}}
        <span class="modifier">
          (+{{localize "ROS5E.Corruption.BaseThreshold"}}:
          {{thresholdBase}})
        </span>
        <span class="total">{{localize "ROS5E.Corruption.Total"}}:
          <span
            class="total-threshold-value"
            data-field="bonus"
          >{{totals.threshold}}</span>
        </span>
      </div>
    </div>
  </div>
  <footer class="sheet-footer flexrow" style="margin-top: 1rem;">
    <button type="submit" name="submit">
      <i class="far fa-save"></i>
      Update
    </button>
  </footer>
</div>